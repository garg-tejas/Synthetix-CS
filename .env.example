# --- Z.AI / GLM (recommended) ---
# Set these to use GLM-4.7-flash. Get key from Z.AI.
LLM_BASE_URL=https://api.z.ai/api/paas/v4/
LLM_API_KEY=your-Z.AI-api-key
LLM_MODEL=glm-4.7-flash

# --- ModelScope (alternative) ---
# Uncomment and set if not using Z.AI. Get token: https://modelscope.cn/my/myaccesstoken
# MODELSCOPE_API_TOKEN=your_token_here
# MODELSCOPE_MODEL=deepseek-ai/DeepSeek-R1-0528
# MODELSCOPE_API_URL=https://api-inference.modelscope.ai/v1

# --- RAG (embedding and reranker) ---
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Database & Auth ---
# PostgreSQL connection URL (async)
# Local example:
#   postgresql+asyncpg://user:password@localhost:5432/cs_rag
# Railway example (see notes below):
#   postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cs_rag

# JWT settings for auth
# JWT_SECRET=your-jwt-secret
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS / Frontend origins ---
# Comma-separated list of allowed origins for the API.
# Local dev default is http://localhost:5173 if unset.
# Examples:
#   BACKEND_CORS_ORIGINS=http://localhost:5173
#   BACKEND_CORS_ORIGINS=https://your-frontend.vercel.app
#   BACKEND_CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
# To temporarily allow all origins (no credentials):
#   BACKEND_CORS_ORIGINS=*
# BACKEND_CORS_ORIGINS=http://localhost:5173
